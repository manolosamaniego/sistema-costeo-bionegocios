{
  "name": "sistema-costeo-bionegocios",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "edition:matriz": "powershell -ExecutionPolicy Bypass -File scripts\\activar-edicion.ps1 -Edition matriz",
    "edition:operativa": "powershell -ExecutionPolicy Bypass -File scripts\\activar-edicion.ps1 -Edition operativa",
    "license:matriz": "powershell -ExecutionPolicy Bypass -File scripts\\activar-licencia-cliente.ps1 -Mode matriz",
    "license:client": "powershell -ExecutionPolicy Bypass -File scripts\\activar-licencia-cliente.ps1 -Mode cliente",
    "license:generate": "powershell -ExecutionPolicy Bypass -File scripts\\generar-licencia-cliente.ps1",
    "release:prepare": "powershell -ExecutionPolicy Bypass -File scripts\\preparar-release.ps1 -Version 1.0.0",
    "client:prepare": "powershell -ExecutionPolicy Bypass -File scripts\\preparar-entrega-cliente.ps1",
    "update:publish": "powershell -ExecutionPolicy Bypass -File scripts\\publicar-manifiesto-actualizacion.ps1",
    "support:check": "powershell -ExecutionPolicy Bypass -File scripts\\verificar-entorno.ps1",
    "support:update": "powershell -ExecutionPolicy Bypass -File scripts\\actualizar-matriz.ps1",
    "dev": "node dev-server.mjs",
    "tauri": "tauri"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
