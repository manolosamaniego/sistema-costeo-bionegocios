{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sistema Comercial de Costeo para Bionegocios",
  "version": "1.0.11",
  "identifier": "com.junglelab.costeo.bionegocios",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Sistema Comercial de Costeo para Bionegocios",
        "width": 1440,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "maximized": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
